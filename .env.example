# Server
APP_PORT=8080
APP_ENV=development

# Admin
ADMIN_PORT=8082

# Socket
SOCKET_PORT=8081

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# NATS
NATS_URL=nats://localhost:4222

# Elasticsearch
ELASTICSEARCH_ADDRESSES=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_PRODUCT_INDEX=products

# Logging
LOG_LEVEL=info
LOGSTASH_ADDRESS=localhost:5044

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=retail_store
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
